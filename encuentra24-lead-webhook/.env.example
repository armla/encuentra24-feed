# ─────────────────────────────────────────────────────────────────
# Encuentra24 Webhook — Environment Configuration
# The Agency Costa Rica
# Copy this file to .env and fill in your values before deploying.
# ─────────────────────────────────────────────────────────────────

# Optional: shared secret Encuentra24 will send in X-Webhook-Secret header
# Leave blank to disable validation (not recommended for production)
WEBHOOK_SECRET=your_strong_random_secret_here

# Google Sheets spreadsheet ID where leads will be logged
# Get it from the URL: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=your_google_sheet_id_here

# Comma-separated list of team email addresses to notify on each lead
NOTIFY_EMAILS=broker@theagencycr.com,assistant@theagencycr.com

# Gmail address used as the sender (must match the authenticated gws account)
SENDER_EMAIL=notifications@theagencycr.com

# Port the Flask server listens on (default 5050)
PORT=5050
